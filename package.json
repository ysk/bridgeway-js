{
  "name": "bridgey",
  "version": "1.2.0",
  "description": "jQueryの書き味で本物のモダンフレームワーク(Svelte/Vue)を、限りなく楽に。エンジン差し替え式。",
  "type": "module",
  "main": "dist/bridgey.esm.js",
  "module": "dist/bridgey.esm.js",
  "exports": {
    ".": "./dist/bridgey.esm.js",
    "./global": "./dist/bridgey.js",
    "./engines/svelte.js": "./dist/engines/svelte.js",
    "./engines/vue.js": "./dist/engines/vue.js"
  },
  "bin": {
    "brg": "bin/bridgey.js",
    "bridgey": "bin/bridgey.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "THIRD-PARTY-NOTICES.md"
  ],
  "unpkg": "dist/bridgey.vue.js",
  "jsdelivr": "dist/bridgey.vue.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:demos": "node build.demo.mjs",
    "prepack": "node build.mjs"
  },
  "keywords": [
    "jquery",
    "svelte",
    "vue",
    "reactive",
    "legacy-migration"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysk/bridgeway-js.git"
  },
  "homepage": "https://github.com/ysk/bridgeway-js#readme",
  "bugs": {
    "url": "https://github.com/ysk/bridgeway-js/issues"
  },
  "peerDependencies": {
    "svelte": "^4",
    "vue": "^3"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "jsdom": "^29.1.1",
    "rollup": "^4.62.2",
    "rollup-plugin-svelte": "^7.2.3",
    "svelte": "^4.2.20",
    "vue": "^3.5.39"
  }
}
